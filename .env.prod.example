# Production Environment Configuration Example
# Copy this file to .env.prod and update the values

# Frontend URL (update with your actual domain)
API_URL=https://your-domain.com

# Frontend API Configuration
VITE_TG_BOT_NAME=your_production_telegram_bot_name
VITE_VERSION=${npm_package_version}
VITE_TEST_ENV=false

# MongoDB Configuration
MONGODB_USERNAME=your_mongodb_username
MONGODB_PASSWORD=your_secure_mongodb_password
MONGODB_DATABASE=hd-prod

# JWT Secret (generate a strong secret)
JWT_SECRET=your_very_secure_jwt_secret_key_here_minimum_256_bits

# Telegram Bot Configuration
# TG_TOKEN: Bot token from @BotFather for telegram bot operations
TG_TOKEN=your_telegram_bot_token_from_botfather
# TG_API_TOKEN: Authentication token for backend-to-telegram-bot communication
TG_API_TOKEN=your_telegram_api_token_here

# Application Configuration
TICKET_COUNTER_STARTING_NUMBER=1
ADD_TICKET_LOG=true

# Node.js Environment
NODE_ENV=production

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# File Upload Configuration
MAX_FILE_SIZE=10485760

# Logging Configuration
LOG_LEVEL=info
LOG_MAX_SIZE=10m
LOG_MAX_FILES=10

# Database Connection Pool
DB_MAX_POOL_SIZE=10
DB_MIN_POOL_SIZE=5

# Session Configuration
SESSION_SECRET=your_session_secret_here
SESSION_MAX_AGE=86400000

# API Configuration
API_TIMEOUT=30000
API_RETRY_ATTEMPTS=3

# Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_SAMPLE_RATE=0.1

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# S3 / Object Storage (Yandex Cloud) — new uploads go to S3; old files stay local.
# Loaded by both backend and telegram-bot via env_file.
S3_ACCESS_KEY_ID=your_s3_access_key_id
S3_SECRET_ACCESS_KEY=your_s3_secret_access_key
S3_BUCKET_NAME=your_s3_bucket_name
S3_REGION=ru-central1
S3_ENDPOINT=https://storage.yandexcloud.net
S3_FORCE_PATH_STYLE=true
# S3_KMS_KEY_ID=your_kms_key_id

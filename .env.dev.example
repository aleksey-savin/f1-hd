# Development Environment Configuration Example
# Copy this file to .env.dev and update the values

# Backend Configuration
ADDRESS='http://localhost:3000'
TG_API_TOKEN='your_telegram_api_token_here'
MONGODB_USERNAME='your_mongodb_username'
MONGODB_PASSWORD='your_mongodb_password'
MONGODB_DATABASE='hd-dev'
JWT_SECRET='your_jwt_secret_key_here_minimum_32_characters'
TICKET_COUNTER_STARTING_NUMBER=100000

# Frontend Configuration
VITE_API_ADDRESS='http://localhost:8080'
VITE_TEST_ENV=true
VITE_TG_BOT_NAME='your_telegram_bot_name'

# MongoDB Initialization
MONGO_INITDB_ROOT_USERNAME='your_mongodb_username'
MONGO_INITDB_ROOT_PASSWORD='your_mongodb_password'

# Telegram Bot Configuration
TG_TOKEN='your_telegram_bot_token_from_botfather'
TG_API_TOKEN='your_telegram_api_token_here'
ADD_TICKET_LOG=true

# Additional Backend Configuration
MONGODB_USERNAME='your_mongodb_username'
MONGODB_PASSWORD='your_mongodb_password'
MONGODB_DATABASE='hd-dev'
ADDRESS='http://127.0.0.1:3000'
